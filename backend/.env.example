# Backend env

# Puerto del API
PORT=4000

# Conexion PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# TMDb
TMDB_API_KEY=YOUR_API_KEY
TMDB_READ_TOKEN=YOUR_READ_TOKEN

# Localizacion
TMDB_LANG=es-ES
TMDB_REGION=CL

# CORS (opcional, separar por comas)
# FRONTEND_ORIGIN=https://tu-app.vercel.app,https://otra-url
FRONTEND_ORIGIN=
