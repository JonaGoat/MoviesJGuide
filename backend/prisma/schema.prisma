generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  displayName String?
  devices     Device[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Device {
  id        String     @id @default(cuid())
  deviceKey String     @unique
  userId    String?
  user      User?      @relation(fields: [userId], references: [id])
  favorites Favorite[]
  playlists Playlist[]
  createdAt DateTime   @default(now())
}

model Phase {
  id     String  @id @default(cuid())
  name   String  @unique
  order  Int
  movies Movie[]
}

model Genre {
  id     String       @id @default(cuid())
  name   String       @unique
  movies MovieGenre[]
}

model Movie {
  id           String          @id
  title        String
  year         Int
  heroKey      String
  color        String
  chronoOrder  Int
  releaseOrder Int
  runtime      String?
  rating       Float?
  description  String?
  trailerUrl   String?
  posterPath   String
  bannerPath   String
  isUpcoming   Boolean         @default(false)
  tmdbId       Int?
  phaseId      String
  phase        Phase           @relation(fields: [phaseId], references: [id])
  genres       MovieGenre[]
  favorites    Favorite[]
  playlistItems PlaylistItem[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([phaseId])
  @@index([chronoOrder])
  @@index([releaseOrder])
}

model MovieGenre {
  movieId String
  genreId String
  movie   Movie @relation(fields: [movieId], references: [id])
  genre   Genre @relation(fields: [genreId], references: [id])

  @@id([movieId, genreId])
  @@index([genreId])
}

model Favorite {
  id        String   @id @default(cuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  movieId   String
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([deviceId, movieId])
  @@index([movieId])
}

model Playlist {
  id        String         @id @default(cuid())
  deviceId  String
  device    Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  name      String
  items     PlaylistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([deviceId])
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  movieId    String
  movie      Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  order      Int
  createdAt  DateTime @default(now())

  @@unique([playlistId, movieId])
  @@index([movieId])
}
